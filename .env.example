# Dependency Track integration (used only in --scan-full)
# If URL or API_KEY is not set, upload step is silently skipped.

DEPENDENCY_TRACK_URL=https://dt.example.com
DEPENDENCY_TRACK_API_KEY=odt_your_api_key_here
DEPENDENCY_TRACK_INSECURE=false

# Project UUIDs — get them from DT Settings → Projects
# Packages project: receives rpm or deb SBOM
DEPENDENCY_TRACK_PROJECT_PACKAGES=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Binary project: receives binary.json (Go/Rust/.NET/Java)
DEPENDENCY_TRACK_PROJECT_BINARY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Repack project: receives repack.cdx.json (Trivy full scan)
DEPENDENCY_TRACK_PROJECT_REPACK=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
